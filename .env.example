# ============================================================
# CHE GOLOSO - Variables de Entorno
# ============================================================
# DESARROLLO LOCAL: Copiar como .env
# RAILWAY: Configurar en el dashboard > Variables
# ============================================================

# ---- OBLIGATORIAS EN PRODUCCIÓN ----

# Clave secreta de Django (generar una nueva para producción)
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here-change-this-in-production

# Modo debug (SIEMPRE False en producción)
DEBUG=True

# Base de datos PostgreSQL
# Railway la configura AUTOMÁTICAMENTE al agregar el plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Hosts permitidos (separados por coma)
# Railway configura RAILWAY_PUBLIC_DOMAIN automáticamente
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- SUPERUSUARIO INICIAL (solo primer deploy) ----
# Se usa en el release command para crear el admin automáticamente
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CambiarEstaClave123!
DJANGO_SUPERUSER_EMAIL=admin@chegoloso.com

# ---- OPCIONALES ----

# Puerto (Railway lo configura automáticamente via $PORT)
# PORT=8000

# Nivel de log de Django
DJANGO_LOG_LEVEL=INFO

# OpenAI API Key (para el asistente IA)
# Puede configurarse también desde la interfaz del sistema
OPENAI_API_KEY=

# ---- VARIABLES AUTOMÁTICAS DE RAILWAY (NO configurar manualmente) ----
# RAILWAY_PUBLIC_DOMAIN  → Dominio público asignado
# RAILWAY_ENVIRONMENT    → Entorno (production, etc.)
# PORT                   → Puerto asignado por Railway
# DATABASE_URL           → Se configura al agregar PostgreSQL plugin
